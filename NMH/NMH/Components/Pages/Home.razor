@page "/home"
@layout LandingLayout

<PageTitle>Nethra Media Hub</PageTitle>

<section class="landing-content">
    <h1>Bienvenue dans NMH App 🚀</h1>
    <p>Découvrez votre hub de films et séries.</p>

    <div class="cta-buttons">
        <a href="/login" class="btn">Se connecter</a>
        <a href="/register" class="btn">S'inscrire</a>
    </div>

    <hr />

    <h2>Instructions rapides :</h2>
    <ul>
        <li>Inscrivez un nouvel utilisateur via la page Register.</li>
        <li>Connectez-vous avec Login.</li>
        <li>Accédez à votre Home utilisateur après connexion.</li>
        <li>Testez l’accès aux pages protégées.</li>
    </ul>
</section>