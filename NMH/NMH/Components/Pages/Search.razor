@page "/search"
@namespace NMH.Components.Pages
@inject NMH.Services.TmdbService TmdbService
@using NMH.Shared.DTOs

<h2 class="mb-4">Recherche Films & Séries</h2>

<p>@testMessage</p>

<hr>

<div class="card shadow-sm mb-4">
    <div class="card-body">

        <input class="form-control mb-3"
               placeholder="Tape quelque chose..."
               @bind="query"
               @bind:event="oninput" />

        <button class="btn btn-secondary mb-3" @onclick="ToggleAdvancedSearch">
            @(showAdvanced ? "Réduire" : "Afficher options")
        </button>

        @if (showAdvanced)
        {
            <div class="border p-3 mb-3">
                <input class="form-control mb-2" placeholder="Année" @bind="year" />
                <input class="form-control mb-2" placeholder="Acteur" @bind="actor" />
            </div>
        }

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="SearchAsync" disabled="@(!CanSearch)">
                Rechercher
            </button>
            <button class="btn btn-outline-secondary" @onclick="ResetSearch">
                Reset
            </button>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="alert alert-info">Chargement...</div>
}

@if (results?.Any() == true)
{
    <div class="row row-cols-4 g-3 mb-3">
        @foreach (var movie in PaginatedResults)
        {
            <div class="col">
                <MovieCard Movie="@movie" />
            </div>
        }
    </div>

    <!-- Pagination -->
    <Pagination CurrentPage="@CurrentPage"
                TotalPages="@TotalPages"
                OnPageChanged="ChangePage" />
}
else if (!string.IsNullOrWhiteSpace(resultMessage))
{
    <div class="alert alert-warning mt-3">@resultMessage</div>
}

@code {
    private string query = "";
    private string actor = "";
    private string year = "";

    private bool showAdvanced = false;
    private bool isLoading = false;

    private string resultMessage = "";
    private string testMessage = "";

    private List<MovieDto> results = new();

    private int PageSize = 20;
    private int CurrentPage = 1;

    private int TotalPages => (int)Math.Ceiling((double)results.Count / PageSize);

    private bool CanSearch => !string.IsNullOrWhiteSpace(query);

    private IEnumerable<MovieDto> PaginatedResults => results
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize);

    private void TestClick() => testMessage = "Blazor fonctionne ✔";

    private void ToggleAdvancedSearch() => showAdvanced = !showAdvanced;

    private async Task SearchAsync()
    {
        isLoading = true;
        resultMessage = "";
        results.Clear();
        CurrentPage = 1;

        try
        {
            // Appel TMDB
            var response = await TmdbService.SearchAsync(
                query,
                mediaType: "movie",
                year: string.IsNullOrWhiteSpace(year) ? null : int.Parse(year),
                actor: string.IsNullOrWhiteSpace(actor) ? null : actor,
                page: CurrentPage
            );

            results = response?.Results?.Select(r => new MovieDto
            {
                Id = r.Id,
                Title = r.Title ?? r.Name ?? "",
                Overview = r.Overview ?? "",
                PosterPath = r.PosterPath ?? "",
                ReleaseDate = DateTime.TryParse(r.ReleaseDate, out var dt) ? dt : null
            }).ToList() ?? new List<MovieDto>();

            if (!results.Any())
                resultMessage = "Aucun résultat trouvé.";
        }
        catch
        {
            resultMessage = "Erreur lors de la recherche.";
        }

        isLoading = false;
    }

    private void ResetSearch()
    {
        query = "";
        actor = "";
        year = "";
        results.Clear();
        resultMessage = "";
    }

    private void ChangePage(int page)
    {
        CurrentPage = page;
        _ = SearchAsync(); // Recharge les résultats pour la nouvelle page
    }
}